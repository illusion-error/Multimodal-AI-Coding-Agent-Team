# 阿里云百炼 API Key。复制本文件为 .env 后在本地填写，禁止提交真实密钥。
DASHSCOPE_API_KEY=

# 后端服务配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=True

# SQLite 数据库路径
DATABASE_PATH=backend/data/tasks.db

# 多个前端来源使用英文逗号分隔
ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Vue 前端配置
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_ENABLE_STAGE2=false

# 图片上传限制
MAX_IMAGE_BYTES=10485760
MAX_IMAGE_PIXELS=25000000
