    "task_id": "U001",
    "title": "盛最多水的容器",
    "category": "双指针",
    "difficulty": "中等",
    "problem_text": "给定一个长度为 n 的整数数组 height。有 n 条垂线，第 i 条线的两个端点是 (i, 0) 和 (i, height[i])。找出其中的两条线，使得它们与 x 轴共同构成的容器可以容纳最多的水。返回容器可以储存的最大水量。函数名：solution(height)",
    "test_cases": [
      {"name": "公开用例", "input": "[1,8,6,2,5,4,8,3]", "expected": "49", "category": "public"},
      {"name": "隐藏用例1", "input": "[1,1]", "expected": "1", "category": "hidden"},
      {"name": "隐藏用例2", "input": "[4,3,2,1,4]", "expected": "16", "category": "hidden"},
      {"name": "隐藏用例3", "input": "[1,2,1]", "expected": "2", "category": "hidden"}
    ]
  },
  {
