      {"name": "隐藏用例2", "input": "[[1]]", "expected": "[1]", "category": "hidden"},
      {"name": "隐藏用例3", "input": "[[1,2],[3,4]]", "expected": "[1, 2, 4, 3]", "category": "hidden"}
