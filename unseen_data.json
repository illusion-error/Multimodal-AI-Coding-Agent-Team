        "category": "public"
      },
      {
        "name": "隐藏用例1",
        "input": "[10, 10, 10]",
        "expected": "0",
        "category": "hidden"
      },
      {
        "name": "隐藏用例2",
        "input": "[]",
        "expected": "0",
        "category": "hidden"
      }
    ]
  }
