      {"name": "隐藏用例2", "input": "[1]", "expected": "[[1]]", "category": "hidden"},
      {"name": "隐藏用例3", "input": "[]", "expected": "[[]]", "category": "hidden"}
    ]
  },
  {
    "task_id": "U004",
