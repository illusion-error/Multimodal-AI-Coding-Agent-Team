  {
    "task_id": "U001",
    "title": "有效字母异位词",
    "category": "哈希表",
    "difficulty": "简单",
    "problem_text": "给定两个字符串 s 和 t，判断 t 是否是 s 的字母异位词。字母异位词要求两个字符串包含完全相同的字符及出现次数。函数名：solution(s, t)",
    "test_cases": [
      {
        "name": "公开用例1",
        "input": "'anagram', 'nagaram'",
        "expected": "True",
        "category": "public"
      },
      {
        "name": "公开用例2",
        "input": "'rat', 'car'",
        "expected": "False",
        "category": "public"
      },
      {
        "name": "隐藏用例1",
        "input": "'aacc', 'ccac'",
        "expected": "False",
        "category": "hidden"
      }
    ]
  },
  {
    "task_id": "U002",
    "title": "右旋数组",
    "category": "数组",
    "difficulty": "简单",
    "problem_text": "给定整数列表 nums 和非负整数 k，请将数组向右轮转 k 个位置，并返回轮转后的新列表。函数名：solution(nums, k)",
    "test_cases": [
      {
        "name": "公开用例1",
        "input": "[1, 2, 3, 4, 5, 6, 7], 3",
        "expected": "[5, 6, 7, 1, 2, 3, 4]",
        "category": "public"
      },
      {
        "name": "隐藏用例1",
        "input": "[-1, -100, 3, 99], 2",
        "expected": "[3, 99, -1, -100]",
        "category": "hidden"
      },
      {
        "name": "隐藏用例2",
        "input": "[1, 2], 5",
        "expected": "[2, 1]",
        "category": "hidden"
      }
    ]
  },
  {
    "task_id": "U003",
    "title": "压缩连续字符",
    "category": "字符串",
    "difficulty": "中等",
    "problem_text": "给定一个字符串 s，请把连续重复字符压缩成字符加次数的形式；如果某个字符只出现 1 次，也要保留次数 1。函数名：solution(s)",
    "test_cases": [
      {
        "name": "公开用例1",
        "input": "'aaabbc'",
        "expected": "'a3b2c1'",
        "category": "public"
      },
      {
        "name": "隐藏用例1",
        "input": "'abcd'",
        "expected": "'a1b1c1d1'",
        "category": "hidden"
      },
      {
        "name": "隐藏用例2",
        "input": "''",
        "expected": "''",
        "category": "hidden"
      }
    ]
  },
  {
    "task_id": "U004",
    "title": "展平嵌套列表",
    "category": "递归",
    "difficulty": "中等",
    "problem_text": "给定一个只包含整数或列表的嵌套列表 nested，请按从左到右顺序返回所有整数组成的一维列表。函数名：solution(nested)",
    "test_cases": [
      {
        "name": "公开用例1",
        "input": "[1, [2, 3], [4, [5]]]",
        "expected": "[1, 2, 3, 4, 5]",
        "category": "public"
      },
      {
        "name": "隐藏用例1",
        "input": "[[[]], [1], 2, [3, [4, []]]]",
        "expected": "[1, 2, 3, 4]",
        "category": "hidden"
      },
      {
        "name": "隐藏用例2",
        "input": "[]",
        "expected": "[]",
        "category": "hidden"
      }
    ]
  },
  {
