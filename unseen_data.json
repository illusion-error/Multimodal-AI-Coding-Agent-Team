    "category": "数组",
    "difficulty": "简单",
    "problem_text": "给定整数列表 nums，请返回严格大于列表平均值的元素个数。空列表返回 0。函数名：solution(nums)",
    "test_cases": [
      {
        "name": "公开用例1",
        "input": "[1, 2, 3, 4, 5]",
